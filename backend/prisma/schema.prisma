// ============================================================
//  Lead Finder — Prisma Schema
//  DER v2.0 — Sprint 1 
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
//  ROLES
// ─────────────────────────────────────────────────────────────
model roles {
  id_role     Int        @id @default(autoincrement())
  nombre      String     @unique @db.VarChar(50)
  descripcion String?    @db.Text
  usuarios    usuarios[]
}

// ─────────────────────────────────────────────────────────────
//  USUARIOS
// ─────────────────────────────────────────────────────────────
model usuarios {
  id_usuario          Int       @id @default(autoincrement())
  nombre              String    @db.VarChar(100)
  apellido            String    @db.VarChar(100)
  email               String    @unique @db.VarChar(150)
  password_hash       String    @db.VarChar(255)
  telefono            String?   @db.VarChar(30)
  activo              Boolean   @default(true)
  fecha_creacion      DateTime  @default(now())
  fecha_ultimo_acceso DateTime?
  token_reset         String?   @db.VarChar(255)
  id_role             Int

  role    roles    @relation(fields: [id_role], references: [id_role])
  leads   leads[]  @relation("LeadAsignado")
  visitas visitas[]
}

// ─────────────────────────────────────────────────────────────
//  ESTADOS_LEAD
// ─────────────────────────────────────────────────────────────
model estados_lead {
  id_estado   Int     @id @default(autoincrement())
  nombre      String  @unique @db.VarChar(50)
  descripcion String? @db.Text
  orden       Int
  activo      Boolean @default(true)

  leads               leads[]
  transiciones_origen transiciones_estado[] @relation("TransicionOrigen")
  transiciones_destino transiciones_estado[] @relation("TransicionDestino")
}

// ─────────────────────────────────────────────────────────────
//  TRANSICIONES_ESTADO
// ─────────────────────────────────────────────────────────────
model transiciones_estado {
  id_transicion  Int @id @default(autoincrement())
  estado_origen  Int
  estado_destino Int

  origen  estados_lead @relation("TransicionOrigen",  fields: [estado_origen],  references: [id_estado])
  destino estados_lead @relation("TransicionDestino", fields: [estado_destino], references: [id_estado])

  @@unique([estado_origen, estado_destino])
}

// ─────────────────────────────────────────────────────────────
//  EMPRESAS
// ─────────────────────────────────────────────────────────────
model empresas {
  id_empresa         Int      @id @default(autoincrement())
  nombre_empresa     String   @db.VarChar(200)
  cuit               String   @unique @db.VarChar(20)
  actividad_principal String? @db.VarChar(200)
  provincia          String?  @db.VarChar(100)
  localidad          String?  @db.VarChar(100)
  direccion          String?  @db.Text
  latitud            Decimal? @db.Decimal(10, 7)
  longitud           Decimal? @db.Decimal(10, 7)
  renspa             String?  @db.VarChar(50)
  tipo_explotacion   String?  @db.VarChar(5)
  superficie         Decimal? @db.Decimal(10, 2)
  fecha_creacion     DateTime @default(now())

  leads     leads[]
  contactos contactos[]
  senasa    senasa[]
  arca      arca[]
  bcra      bcra[]
}

// ─────────────────────────────────────────────────────────────
//  LEADS
// ─────────────────────────────────────────────────────────────
model leads {
  id_lead               Int       @id @default(autoincrement())
  id_empresa            Int       @unique
  id_estado             Int
  score_viabilidad      Decimal?  @db.Decimal(5, 2)
  situacion_crediticia  Int?
  fuente_origen         String?   @db.VarChar(100)
  observaciones         String?   @db.Text
  fecha_creacion        DateTime  @default(now())
  fecha_ultima_actividad DateTime?
  id_usuario_asignado   Int?
  fecha_asignacion      DateTime?
  fecha_conversion      DateTime?

  empresa  empresas     @relation(fields: [id_empresa],          references: [id_empresa])
  estado   estados_lead @relation(fields: [id_estado],           references: [id_estado])
  usuario  usuarios?    @relation("LeadAsignado", fields: [id_usuario_asignado], references: [id_usuario])
  visitas  visitas[]
}

// ─────────────────────────────────────────────────────────────
//  CONTACTOS
// ─────────────────────────────────────────────────────────────
model contactos {
  id_contacto        Int      @id @default(autoincrement())
  id_empresa         Int
  nombre             String?  @db.VarChar(100)
  apellido           String?  @db.VarChar(100)
  telefono           String?  @db.VarChar(50)
  email              String?  @db.VarChar(150)
  cargo              String?  @db.VarChar(100)
  contacto_principal Boolean  @default(false)
  fecha_creacion     DateTime @default(now())

  empresa empresas @relation(fields: [id_empresa], references: [id_empresa])
}

// ─────────────────────────────────────────────────────────────
//  VISITAS
// ─────────────────────────────────────────────────────────────
model visitas {
  id_visita      Int      @id @default(autoincrement())
  id_lead        Int
  id_usuario     Int
  fecha_visita   DateTime
  resultado      String?  @db.VarChar(100)
  comentarios    String?  @db.Text
  latitud        Decimal? @db.Decimal(10, 7)
  longitud       Decimal? @db.Decimal(10, 7)
  fecha_creacion DateTime @default(now())

  lead    leads    @relation(fields: [id_lead],    references: [id_lead])
  usuario usuarios @relation(fields: [id_usuario], references: [id_usuario])
}

// ─────────────────────────────────────────────────────────────
//  SENASA
// ─────────────────────────────────────────────────────────────
model senasa {
  id_senasa            Int       @id @default(autoincrement())
  id_empresa           Int
  renspa               String    @unique @db.VarChar(50)
  titular              String?   @db.VarChar(200)
  tipo_explotacion     String?   @db.VarChar(5)
  superficie           Decimal?  @db.Decimal(10, 2)
  nombre_establecimiento String? @db.VarChar(200)
  poligono             String?   @db.Text
  fecha_baja           DateTime?
  fecha_consulta       DateTime?

  empresa empresas @relation(fields: [id_empresa], references: [id_empresa])
}

// ─────────────────────────────────────────────────────────────
//  ARCA
// ─────────────────────────────────────────────────────────────
model arca {
  id_arca          Int       @id @default(autoincrement())
  id_empresa       Int
  cuit             String    @unique @db.VarChar(20)
  denominacion     String?   @db.VarChar(200)
  imp_ganancias    String?   @db.VarChar(10)
  imp_iva          String?   @db.VarChar(10)
  monotributo      String?   @db.VarChar(10)
  empleador        String?   @db.VarChar(5)
  actividad_codigo String?   @db.VarChar(20)
  fecha_consulta   DateTime?

  empresa empresas @relation(fields: [id_empresa], references: [id_empresa])
}

// ─────────────────────────────────────────────────────────────
//  BCRA
// ─────────────────────────────────────────────────────────────
model bcra {
  id_bcra              Int       @id @default(autoincrement())
  id_empresa           Int
  cuit                 String    @unique @db.VarChar(20)
  denominacion         String?   @db.VarChar(200)
  periodo              String?   @db.VarChar(10)
  entidad              String?   @db.VarChar(200)
  situacion_crediticia Int?
  proceso_judicial     Boolean?  @default(false)
  fecha_consulta       DateTime?

  empresa empresas @relation(fields: [id_empresa], references: [id_empresa])
}